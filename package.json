{
  "name": "resume-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Resume Portfolio starter project with React + Wix Design System and Express API",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"yarn dev:server\" \"yarn dev:client\"",
    "dev:client": "yarn workspace client dev",
    "dev:server": "yarn workspace server dev"
  },
  "keywords": [
    "portfolio",
    "resume",
    "react",
    "wix-design-system"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "packageManager": "yarn@4.12.0"
}
